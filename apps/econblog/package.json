{
  "name": "@adamsaxion/econblog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: econblog'",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed-database.ts",
    "seed:pricewar": "tsx scripts/seed-pricewar.ts",
    "pricewar:replay": "tsx scripts/pricewar-replay.ts",
    "test:e2e": "playwright test",
    "test:e2e:pricewar": "playwright test e2e/pricewar",
    "load:pricewar": "k6 run scripts/k6/pricewar-vs-bot.js -e BASE_URL=${PLAYWRIGHT_BASE_URL:-http://localhost:3000}",
    "load:pricewar:queue": "k6 run scripts/k6/pricewar-queue.js -e BASE_URL=${PLAYWRIGHT_BASE_URL:-http://localhost:3000}",
    "load:pricewar:submit-spike": "k6 run scripts/k6/pricewar-submit-spike.js -e BASE_URL=${PLAYWRIGHT_BASE_URL:-http://localhost:3000}",
    "load:pricewar:sse": "k6 run scripts/k6/pricewar-sse.js -e BASE_URL=${PLAYWRIGHT_BASE_URL:-http://localhost:3000}",
    "db:migrate-lessons": "tsx scripts/migrate-lessons-to-db.ts",
    "batch:generate": "tsx scripts/batch-generate.ts",
    "batch:resume": "tsx scripts/batch-generate.ts --resume",
    "worker:lessons": "node --import tsx scripts/lesson-generation-worker.ts",
    "test:serpapi": "tsx scripts/test-serpapi.ts",
    "restart:early-lessons": "tsx scripts/restart-early-lessons.ts",
    "purge:batch": "tsx scripts/purge-and-requeue-batch.ts",
    "resume:lessons": "tsx scripts/resume-lessons.ts",
    "react-doctor": "pnpm exec react-doctor . --yes",
    "react-doctor:verbose": "pnpm exec react-doctor . --verbose --yes",
    "react-doctor:score": "pnpm exec react-doctor . --score --yes",
    "optimize:landing-images": "bash scripts/optimize-landing-images.sh",
    "sync:carousel": "tsx scripts/sync-carousel-thumbnails.ts"
  },
  "dependencies": {
    "@adamsaxion/pricewar-engine": "workspace:*",
    "@adamsaxion/pricewar-types": "workspace:*",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/query-persist-client-core": "^5.85.6",
    "@tanstack/react-query": "^5.85.6",
    "@tanstack/react-query-persist-client": "^5.85.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.542.0",
    "next": "15.5.9",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.9",
    "posthog-js": "^1.261.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.6",
    "react-doctor": "^0.1.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.5",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "esbuild",
      "protobufjs",
      "sharp"
    ]
  }
}
