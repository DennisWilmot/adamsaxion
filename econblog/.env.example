# Supabase Connection Pooler (for app runtime)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Direct Connection (for migrations/drizzle-kit)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-us-west-2.pooler.supabase.com:5432/postgres"

# Supabase Auth — Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
# Enable in Supabase Dashboard → Authentication → Providers:
# - Email (sign up + sign in with password)
# - Google OAuth
# Add redirect URLs (exact path, no query string needed):
#   http://localhost:3000/auth/callback
#   https://your-production-domain/auth/callback
# Also set Supabase Site URL to your production domain (Authentication → URL Configuration).
# NEXT_PUBLIC_APP_URL should match the domain users actually visit.

# Admin access — comma-separated emails allowed to access /admin
ADMIN_EMAILS="your-email@gmail.com"

# Open Router (lesson generation AI)
OPENROUTER_API_KEY="sk-or-..."
OPENROUTER_MODEL="anthropic/claude-sonnet-4"

# SerpAPI (web research for lesson generation) — https://serpapi.com/manage-api-key
# NOT serper.dev — different service, different key.
# Verify: npm run test:serpapi
SERPAPI_API_KEY="your-serpapi-key"

# Stripe — Dashboard → Developers → API keys (use Test mode while building)
# Secret key: server only (checkout, webhooks, portal). Never expose to the browser.
STRIPE_SECRET_KEY="sk_test_..."
# Publishable key: safe for client (Stripe.js / Checkout redirect pages if needed)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook signing secret — Dashboard → Developers → Webhooks → your endpoint → Signing secret
# Local dev: run `stripe listen --forward-to localhost:3000/api/stripe/webhook` and paste the whsec_ it prints
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price IDs — Dashboard → Products → each price → copy price_... (not product id)
STRIPE_PRICE_ID_MONTHLY="price_..."   # $19.99/month subscription
STRIPE_PRICE_ID_LIFETIME="price_..."   # $149 one-time (create as one-time price on a Product)
# Used for Checkout success/cancel URLs and Customer Portal return URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Stripe Customer Portal (Dashboard → Settings → Billing → Customer portal):
# Enable subscription cancel, payment method update, invoice history.

# PostHog (optional — analytics)
# NEXT_PUBLIC_POSTHOG_KEY="phc_..."
# NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
